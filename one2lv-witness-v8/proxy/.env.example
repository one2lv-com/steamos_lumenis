# ∆One2lv∆ Witness — Proxy Environment Template
# Copy to .env and fill in your values
# NEVER commit .env to version control

# Required: Get from https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: NVIDIA model to use
NVIDIA_MODEL=moonshotai/kimi-k2-instruct-0905

# Optional: Server port (default 3000)
PORT=3000

# Optional: development | production
NODE_ENV=development

# Optional: CORS allowed origin
FRONTEND_URL=http://localhost:5173
